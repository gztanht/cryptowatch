# ₿ CryptoWatch 环境配置示例
# 复制此文件为 .env 并填入真实值
# cp .env.example .env

# 价格 API (可选)
# COINGECKO_API_KEY=your_api_key_here
# COINMARKETCAP_API_KEY=your_api_key_here

# 价格警报设置
# ALERT_EMAIL=your_email@example.com
# TELEGRAM_BOT_TOKEN=your_bot_token

# 监控币种 (默认：BTC,ETH,SOL)
# WATCH_LIST=BTC,ETH,SOL,ADA,DOT

# 价格更新间隔 (秒)
REFRESH_INTERVAL=60

# 调试模式
DEBUG=false
